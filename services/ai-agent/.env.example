VALKEY_URL=redis://valkey:6379/0
DATABASE_URL=postgres://paca:paca@postgres:5432/paca
INTERNAL_API_KEY=dev-internal-key-change-in-production
API_BASE_URL=http://api:8080
# Must match AGENT_API_KEY on the api service
PACA_API_KEY=dev-agent-api-key-change-in-production
DOCKER_SOCKET=/var/run/docker.sock
AGENT_SERVER_IMAGE=ghcr.io/openhands/agent-server:latest-python
CONVERSATION_PERSISTENCE_ROOT=/data/conversations
PORT_POOL_START=10000
PORT_POOL_SIZE=100
WORKER_CONCURRENCY=10
LOG_LEVEL=INFO
