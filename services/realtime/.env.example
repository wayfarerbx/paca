# ── services/realtime environment variables ───────────────────────────────────
# Copy this file to .env for local development outside Docker.
# All variables listed here are required unless a default is shown.

# Port the HTTP + Socket.IO server listens on.
PORT=3001

# Internal URL of services/api used for token verification and permission lookups.
# When running outside Docker, point this at the API directly (not through nginx).
API_URL=http://localhost:8080

# Valkey / Redis connection URL.  Must point to the same instance the API uses.
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed CORS origins (browser clients).
CORS_ORIGINS=http://localhost:3000,http://localhost

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to "production" to enable structured JSON logging.
NODE_ENV=development
