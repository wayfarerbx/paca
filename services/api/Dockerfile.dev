FROM golang:1.26-alpine

# Install air once at image-build time so the installation is cached in the
# Docker layer and does not repeat on every container start.
RUN go install github.com/air-verse/air@latest

# Pre-download all Go modules so they are baked into the image layer.
# This avoids a cold module download on every fresh container start.
# Rebuild the image when go.mod/go.sum change.
WORKDIR /deps
COPY go.mod go.sum ./
RUN go mod download

WORKDIR /workspace
