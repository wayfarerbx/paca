# Optional: set when exposing the dev stack through a reverse proxy or tunnel
# (e.g. ngrok, Cloudflare Tunnel, a custom domain).
# Must be the full URL without a trailing slash.
# Defaults to http://localhost when unset.
#
# Example with ngrok:
#   PUBLIC_HOST=https://abc123.ngrok-free.app
#
# Example with a custom domain:
#   PUBLIC_HOST=https://dev.example.com
#
PUBLIC_HOST=http://localhost

# Allow the Vite dev server to accept requests from the same host.
# Set to the hostname only (no scheme or port).
# Required when accessing the web app through a tunnel or custom domain.
#
# Example:
#   VITE_ALLOWED_HOST=dev.example.com
#
VITE_ALLOWED_HOST=

# Optional: override the db-backup service's schedule, retention, and output
# directory. Defaults (in docker-compose.dev.yml) run daily at 02:00 UTC,
# keep 7 days, and write to ./backups (relative to deploy/).
#
# For fast local testing, point BACKUP_CRON at a tight interval instead, e.g.
# every 2 minutes:
#   BACKUP_CRON=*/2 * * * *
#
# BACKUP_DIR=./backups
# BACKUP_CRON=0 2 * * *
# BACKUP_RETENTION_DAYS=7
