# Container images. Override these when pulling from a registry in CI/CD.
PACA_API_IMAGE=paca-api:latest
PACA_WEB_IMAGE=paca-web:latest

# Runtime settings.
ENVIRONMENT=production

# Public URL for the web application (used for VITE_API_BASE_URL).
# This should be the full URL where your Paca instance will be accessible,
# e.g., https://paca.example.com or http://localhost:8080
PUBLIC_URL=http://localhost

# Stateful service credentials.
POSTGRES_DB=paca
POSTGRES_USER=paca
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# Secrets.
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Cookie settings.
COOKIE_SECURE=true

# Default admin account seeded on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Object storage.
# ── Self-hosted with MinIO (default) ────────────────────────────────────────
# Run with: docker compose --env-file deploy/.env.production -f deploy/docker-compose.prod.yml up -d --build
# MinIO is started as a sidecar container using the credentials below.
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
# Public URL through which browsers reach the object store via the nginx gateway.
# Update to match your domain when deploying behind a real hostname.
STORAGE_PUBLIC_URL=http://localhost/storage
STORAGE_REGION=us-east-1
STORAGE_BUCKET=paca
STORAGE_ACCESS_KEY_ID=replace-with-a-strong-minio-access-key
STORAGE_SECRET_ACCESS_KEY=replace-with-a-strong-minio-secret-key
STORAGE_USE_SSL=false

# ── AWS S3 (no MinIO container) ──────────────────────────────────────────────
# Pass --scale minio=0 to the startup command. MinIO will not run.
# STORAGE_PROVIDER=s3
# STORAGE_ENDPOINT=         # leave empty to use the default AWS regional endpoint
# STORAGE_PUBLIC_URL=       # leave empty; AWS S3 presigned URLs are already public
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=your-s3-bucket-name
# STORAGE_ACCESS_KEY_ID=your-aws-access-key-id
# STORAGE_SECRET_ACCESS_KEY=your-aws-secret-access-key
# STORAGE_USE_SSL=true

# GitHub integration (optional).
# When GITHUB_ENCRYPTION_KEY is empty or unset the GitHub feature is disabled.
# To enable it, generate a 32-byte AES-256 key and provide it as a 64-char hex string:
#   openssl rand -hex 32
GITHUB_ENCRYPTION_KEY=
# PUBLIC_URL is reused as the base for the GitHub webhook callback URL.
# The webhook path /api/v1/github/webhook is appended automatically.
# Example: PUBLIC_URL=https://paca.example.com → webhook: https://paca.example.com/api/v1/github/webhook