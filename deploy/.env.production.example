# Container images. Override these when pulling from a registry in CI/CD.
PACA_API_IMAGE=paca-api:latest
PACA_WEB_IMAGE=paca-web:latest
PACA_REALTIME_IMAGE=paca-realtime:latest

# Runtime settings.
ENVIRONMENT=production

# Cloud deployments:
# - AWS S3: Set STORAGE_PROVIDER=s3 and real AWS credentials. Run with --scale minio=0
# Environment variables below have defaults for self-hosted deployments and are optional when using cloud services.

# Public URL for the web application and plugin callbacks.
# This should be the full URL where your Paca instance will be accessible,
# e.g., https://paca.example.com or http://localhost:8080
PUBLIC_URL=http://localhost

# Stateful service credentials.
# These are optional when using AWS S3 (--scale minio=0).
# Defaults are provided for self-hosted deployments.
POSTGRES_DB=paca
POSTGRES_USER=paca
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# Database settings.
# Default: postgres://paca:POSTGRES_PASSWORD@postgres:5432/paca?sslmode=disable
DATABASE_URL=

# Redis/Valkey settings.
# Default: redis://valkey:6379/0
REDIS_URL=

# JWT authentication.
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_REFRESH_SESSION_TTL=24h

# Cookie settings.
COOKIE_SECURE=true

# Default admin account seeded on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Cache TTL settings (optional, defaults provided).
# CACHE_PROJECT_TTL=5m      # project detail + member lists
# CACHE_CONFIG_TTL=10m      # task types, statuses, custom fields, roles, global roles
# CACHE_SPRINT_TTL=2m       # sprints and views

# Object storage.
# ── Self-hosted with MinIO (default) ────────────────────────────────────────
# Run with: docker compose --env-file deploy/.env.production -f deploy/docker-compose.prod.yml up -d
# MinIO is started as a sidecar container using the credentials below.
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
# Public URL through which browsers reach the object store via the nginx gateway.
# Update to match your domain when deploying behind a real hostname.
STORAGE_PUBLIC_URL=http://localhost/storage
STORAGE_REGION=us-east-1
STORAGE_BUCKET=paca
STORAGE_ACCESS_KEY_ID=replace-with-a-strong-minio-access-key
STORAGE_SECRET_ACCESS_KEY=replace-with-a-strong-minio-secret-key
STORAGE_USE_SSL=false

# ── AWS S3 (no MinIO container) ──────────────────────────────────────────────
# Pass --scale minio=0 to the startup command. MinIO will not run.
# STORAGE_PROVIDER=s3
# STORAGE_ENDPOINT=         # leave empty to use the default AWS regional endpoint
# STORAGE_PUBLIC_URL=       # leave empty; AWS S3 presigned URLs are already public
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=your-s3-bucket-name
# STORAGE_ACCESS_KEY_ID=your-aws-access-key-id
# STORAGE_SECRET_ACCESS_KEY=your-aws-secret-access-key
# STORAGE_USE_SSL=true

# Encryption key for sensitive values (plugin tokens/secrets).
# Must be a 64-char lowercase hex string (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Plugin subsystem settings.
# Controls where WASM binaries are loaded from.
# "local": reads from the local filesystem (default)
# "s3": reads from the object-storage bucket configured via STORAGE_* variables
PLUGINS_STORE=local
# Local plugin directories (PLUGINS_STORE=local)
PLUGINS_WASM_DIR=/plugins
PLUGINS_FRONTEND_DIR=/plugins-frontend
PLUGINS_MCP_DIR=/plugins-mcp
# S3 prefix for plugins (PLUGINS_STORE=s3)
PLUGINS_S3_PREFIX=plugins
# Public GitHub marketplace catalog URL (raw JSON)
PLUGINS_MARKETPLACE_CATALOG_URL=https://raw.githubusercontent.com/Paca-AI/paca-plugins/master/catalog/plugins.json
PLUGINS_MARKETPLACE_TIMEOUT=20s
